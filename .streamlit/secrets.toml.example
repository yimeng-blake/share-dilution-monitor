# Copy this file to secrets.toml and fill in your Snowflake credentials.
# For Streamlit Cloud: paste these values into the app's Secrets management UI.
# NEVER commit secrets.toml to version control.

[snowflake]
account = "your_account_identifier"
user = "your_username"
password = "your_password"
warehouse = "COMPUTE_WH"
database = "DILUTION_MONITOR"
schema = "PUBLIC"
role = "DILUTION_MONITOR_ROLE"

[github]
pat = "ghp_your_personal_access_token"
