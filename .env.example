# Snowflake connection (used by env-var auth path and GitHub Actions)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=DILUTION_MONITOR
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=ACCOUNTADMIN

# SEC EDGAR (required — must include a real email)
SEC_EDGAR_USER_AGENT=DilutionMonitor your-email@example.com
